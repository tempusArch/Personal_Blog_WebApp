@model PersonalBlog.Views.Admin.CreateBlogModel

<h1>Create Blog</h1>

<form method="post">
    <div class="form-group mt-2">
        <label asp-for="BlogPost.Title"></label>
        <input asp-for="BlogPost.Title" class="form-control">
        <span asp-validation-for="BlogPost.Title" class="text-danger"></span>

        <div class="form-group mt-2">
            <label asp-for="BlogPost.Content"></label>
            <textarea asp-for="BlogPost.Content" class="form-control" rows="15"></textarea>
            <span asp-validation-for="BlogPost.Content" class="text-danger"></span>
        </div>

        <div class="form-group mt-2">
            <label asp-for="BlogPost.Author"></label>
            <input asp-for="BlogPost.Author" class="form-control">
            <span asp-validation-for="BlogPost.Author" class="text-danger"></span>
        </div>

        <button asp-action="Create" type="submit" class="btn btn-danger mt-4" style="float:right">Submit</button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}