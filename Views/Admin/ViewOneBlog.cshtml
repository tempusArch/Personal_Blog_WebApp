@model PersonalBlog.Views.Admin.ViewOneBlogModel

@if (Model != null) {

    <h1>Blog - @Model.Blog.Id</h1>

    <div class="form-group mt-2">
        <label asp-for="@Model.Blog.Title"></label>
        <input asp-for="@Model.Blog.Title" class="form-control" disabled>
    </div>

    <div class="form-group mt-2">
        <label asp-for="@Model.Blog.Content"></label>
        <textarea asp-for="@Model.Blog.Content" class="form-control" rows="15" disabled></textarea>
    </div>

    <div class="form-group mt-2">
        <label asp-for="@Model.Blog.PublishedDate"></label>
        <input asp-for="@Model.Blog.PublishedDate" class="form-control" disabled>
    </div>

    <div class="form-group mt-2">
        <label asp-for="@Model.Blog.Author"></label>
        <input asp-for="@Model.Blog.Author" class="form-control" disabled>
    </div>

} else {
    <p>Model is null</p>
}